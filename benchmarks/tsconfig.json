{
  "include": ["src/**/*.ts"],
  "exclude": ["src/gen"],
  "compilerOptions": {
    "target": "es2022",
    "moduleResolution": "Node10",
    "module": "ES2022",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
